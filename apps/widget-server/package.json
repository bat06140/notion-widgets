{
  "name": "@repo/widget-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json --preserveWatchOutput",
    "dev": "PORT=3001 tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "test": "rm -rf .test-dist && tsc -p tests/tsconfig.json && node --test .test-dist/tests/**/*.test.js"
  },
  "dependencies": {
    "@repo/shared": "file:../../packages/shared",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2"
  }
}
